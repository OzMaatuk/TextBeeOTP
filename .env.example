# OTP Service Configuration

# Core
# API_PORT: backend callers use this port (requires X-API-Key)
# UI_PORT:  browser users use this port (no API key needed)
# Use separate ports in production for proper security isolation.
API_PORT=3008
UI_PORT=8080
NODE_ENV=development

# OTP Settings
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_SECRET=replace-with-a-long-random-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
VERIFY_RATE_LIMIT_MAX=10
JSON_BODY_LIMIT=8kb

# ==== Caller Authentication ====
# Comma-separated list of API keys for authenticating callers.
# Required in production. In non-production, auth is skipped if not set.
API_KEYS=your-api-key-here,optional-second-key

# Optional dedicated key for monitoring/health checks only.
# Accepted on /health and /otp/health but NOT on /otp/send or /otp/verify.
# HEALTH_API_KEY=your-health-monitor-key

# ==== CORS ====
# Comma-separated list of allowed origins.
# Required in production. Defaults to * (allow all) in non-production.
ALLOWED_ORIGINS=https://your-frontend.com

# ==== Proxy Trust ====
# How many proxy hops to trust for client IP (used by rate limiter).
# Required in production. Defaults to 1 in non-production.
# Values: integer (hop count), IP/CIDR string, or "false" to disable.
TRUST_PROXY=1

# Redis (optional - falls back to in-memory if not configured)
# For Redis Cloud (redis.io): use rediss:// protocol for TLS
# Example: rediss://default:password@redis-12345.redis.io:12345
# For local Redis: redis://localhost:6379
# For Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# SMS Provider (TextBee)
# Set to true/1/yes to enable SMS OTP delivery (requires TEXTBEE_API_KEY and TEXTBEE_DEVICE_ID)
ENABLE_SMS_OTP=false
TEXTBEE_API_KEY=your_textbee_api_key_here
TEXTBEE_DEVICE_ID=your_textbee_device_id_here

# Email Provider (Zoho)
EMAIL_FROM=your_zoho_address@yourdomain.com
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_zoho_address@yourdomain.com
SMTP_PASS=your_zoho_app_password

# ==== Auth Token (issued after successful OTP verify) ====
# Secret used to sign the short-lived JWT returned by /ui/otp/verify.
# Must be a long random string. Required for the verify endpoint to work.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
# Lifetime of the token in seconds (60-3600). Default: 300
AUTH_TOKEN_TTL_SECONDS=300
