# TextBeeOTP OIDC Configuration Example
# Copy this file to .env and configure with your values

# ===== OIDC Provider Configuration =====
ENABLE_OIDC=true
OIDC_SERVER_URL=http://localhost:3008
OIDC_CLIENT_ID=oauth2-proxy
OIDC_CLIENT_SECRET=your-secret-key-here-change-in-production
OIDC_REDIRECT_URIS=http://localhost:4180/oauth2/callback,https://your-app.com/oauth2/callback

# ===== OTP Configuration =====
OTP_TTL_SECONDS=600
OTP_LENGTH=6
OTP_SECRET=your-otp-secret-key-change-in-production

# ===== Server Configuration =====
PORT=3008
NODE_ENV=development

# ===== Email Provider Configuration =====
# Using Zoho Mail as example, update SMTP_HOST, SMTP_USER, SMTP_PASS for your provider
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@example.com

# ===== SMS Provider Configuration (TextBee) =====
TEXTBEE_API_KEY=your-api-key
TEXTBEE_DEVICE_ID=your-device-id

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
VERIFY_RATE_LIMIT_MAX=10

# ===== Other Configuration =====
JSON_BODY_LIMIT=8kb
